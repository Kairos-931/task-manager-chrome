{
  "manifest_version": 3,
  "name": "任务管理 - TaskMaster",
  "version": "1.1.0",
  "description": "功能完整的任务管理工具，支持列表/日/周/月视图，帮助你高效管理日常任务",
  "short_name": "任务管理",
  "permissions": ["storage"],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js",
    "type": "classic"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "任务管理",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
