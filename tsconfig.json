{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "noEmit": true
  },
  "include": ["./shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "popup", "newtab", "scripts"]
}
